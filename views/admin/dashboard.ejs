<%- include('../layouts/header') %>
<link rel="stylesheet" href="/css/admin/dashboard.css">

<div class="container dashboard-root">

  <!-- SECTION A: Header -->
  <div class="dashboard-header d-flex align-items-start justify-content-between mb-3">
    <div>
      <h1 class="dashboard-title mb-1">Trang quản trị CineBook</h1>
      <p class="dashboard-subtitle mb-0">Tổng quan: phim, lịch chiếu, rạp, phòng và doanh thu</p>
    </div>
    <div class="ms-3 align-self-center">
      <span class="badge admin-badge">Admin: <%= currentUser ? currentUser.username : '' %></span>
    </div>
  </div>

  <!-- SECTION B: 4 Stat Cards -->
  <div class="stats-grid mb-4">
    <div class="stat-card admin-stat-card">
      <div class="stat-label">Tổng doanh thu</div>
      <div class="stat-value text-danger"><%= (stats.revenue || 0).toLocaleString('vi-VN') %>d</div>
      <div class="stat-note">Từ <strong><%= stats.paidBookings || 0 %></strong> đơn đã thanh toán</div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-label">Phim</div>
      <div class="stat-value"><%= stats.movieCount || 0 %></div>
      <div class="stat-note"><%= stats.showtimeCount || 0 %> suất đang quản lý</div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-label">Rạp</div>
      <div class="stat-value"><%= stats.cinemaCount || 0 %></div>
      <div class="stat-note"><%= stats.roomCount || 0 %> phòng chiếu</div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-label">Người dùng</div>
      <div class="stat-value"><%= stats.userCount || 0 %></div>
      <div class="stat-note"><%= stats.bookingCount || 0 %> booking trong hệ thống</div>
    </div>
  </div>

  <!-- SECTION C: Quick Actions -->
  <div class="quick-actions mb-4">
    <div class="quick-grid">
      <a href="/admin/movies" class="quick-card admin-shortcut">
        <div class="icon-wrap bg-danger-subtle text-danger"><i class="bi bi-film"></i></div>
        <div class="quick-title">Quản lý phim</div>
      </a>
      <a href="/admin/showtimes" class="quick-card admin-shortcut">
        <div class="icon-wrap bg-success-subtle text-success"><i class="bi bi-calendar-week"></i></div>
        <div class="quick-title">Lịch chiếu</div>
      </a>
      <a href="/admin/cinemas" class="quick-card admin-shortcut">
        <div class="icon-wrap bg-primary-subtle text-primary"><i class="bi bi-building"></i></div>
        <div class="quick-title">Quản lý rạp</div>
      </a>
      <a href="/admin/rooms" class="quick-card admin-shortcut">
        <div class="icon-wrap bg-info-subtle text-info"><i class="bi bi-door-open"></i></div>
        <div class="quick-title">Phòng chiếu</div>
      </a>
      <a href="/admin/users" class="quick-card admin-shortcut">
        <div class="icon-wrap bg-warning-subtle text-warning"><i class="bi bi-people"></i></div>
        <div class="quick-title">Người dùng</div>
      </a>
    </div>
  </div>

  <!-- SECTION D: Recent Bookings -->
  <div class="card recent-card border-0 shadow-sm">
    <div class="card-header bg-dark border-secondary d-flex justify-content-between align-items-center">
      <strong>Booking gần đây</strong>
      <a href="/admin/bookings" class="btn btn-sm btn-outline-light">Xem tất cả</a>
    </div>
    <div class="card-body">
      <% if (!recentBookings || recentBookings.length === 0) { %>
        <p class="text-muted mb-0">Chưa có booking nào để hiển thị.</p>
      <% } else { %>
        <div class="table-responsive recent-table-wrap">
          <table class="table table-dark align-middle mb-0 recent-table">
            <thead>
              <tr>
                <th>Khách hàng</th>
                <th>Phim</th>
                <th>Vé</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
              </tr>
            </thead>
            <tbody>
              <% recentBookings.forEach(booking => { %>
                <tr>
                  <td><%= booking.userId ? booking.userId.username : 'Unknown' %></td>
                  <td><%= booking.showtimeId && booking.showtimeId.movieId ? booking.showtimeId.movieId.title : 'N/A' %></td>
                  <td><%= booking.ticketCode || '-' %></td>
                  <td><%= (booking.totalAmount || 0).toLocaleString('vi-VN') %>d</td>
                  <td>
                    <% if (booking.status === 'paid') { %>
                      <span class="badge badge-paid">Đã thanh toán</span>
                    <% } else if (booking.status === 'cancelled') { %>
                      <span class="badge badge-cancelled">Đã hủy</span>
                    <% } else { %>
                      <span class="badge badge-pending">Chờ xử lý</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

</div>

<%- include('../layouts/footer') %>
