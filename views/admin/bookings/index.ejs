<%- include('../../layouts/header') %>
<div class="container mt-4">
  <div class="mb-4">
    <h2><i class="bi bi-wallet2 text-warning"></i> Quản Lý Đơn Đặt Vé</h2>
    <p class="text-secondary">Duyệt thủ công các vé thanh toán qua máy quét Mã QR hoặc Hủy nếu Khách hàng chưa chuyển khoản.</p>
  </div>

  <div class="card bg-dark text-light border-secondary">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
          <thead>
            <tr>
              <th>Mã Đơn / Khách hàng</th>
              <th>Thông tin vé</th>
              <th>Thanh toán</th>
              <th>Trạng thái</th>
              <th class="text-end">Duyệt Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (bookings.length === 0) { %>
              <tr><td colspan="5" class="text-center py-4">Chưa có giao dịch mua vé nào.</td></tr>
            <% } else { %>
              <% bookings.forEach(b => { %>
                <% const d = new Date(b.bookingDate).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', day:'2-digit', month:'2-digit'}) %>
              <tr>
                <td>
                  <span class="text-info font-monospace fw-bold">#<%= b._id.toString().substring(18).toUpperCase() %></span><br>
                  <small class="text-muted"><i class="bi bi-person"></i> <%= b.userId ? b.userId.username : 'Unknown' %></small><br>
                  <small class="text-muted"><i class="bi bi-clock-history"></i> <%= d %></small>
                </td>
                <td>
                   <div class="fw-bold"><%= b.showtimeId && b.showtimeId.movieId ? b.showtimeId.movieId.title : 'N/A' %></div>
                   <% if(b.showtimeId) { %>
                     <span class="small text-muted"><%= b.showtimeId.cinemaId.name %> | <%= b.showtimeId.roomId.name %></span>
                   <% } %>
                   <div>
                     <span class="badge bg-secondary">Ghế: <%= b.tickets.map(t=>t.code).join(',') %></span>
                     <% if (b.ticketCode) { %>
                       <span class="badge bg-info text-dark">Ve: <%= b.ticketCode %></span>
                     <% } %>
                   </div>
                </td>
                <td>
                   <strong class="text-danger"><%= b.totalAmount.toLocaleString() %>đ</strong>
                </td>
                <td>
                  <% if (b.status === 'paid') { %>
                    <span class="badge bg-success">Đã thanh toán (Paid)</span>
                  <% } else if (b.status === 'cancelled') { %>
                    <span class="badge bg-danger">Đã Hủy (Canceled)</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">Chờ Bank (Pending)</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <form action="/admin/bookings/status/<%= b._id %>" method="POST" class="d-flex justify-content-end gap-1">
                    <select name="status" class="form-select form-select-sm bg-dark text-light border-secondary w-auto">
                      <option value="pending" <%= b.status==='pending' ? 'selected' : '' %>>Pending</option>
                      <option value="paid" <%= b.status==='paid' ? 'selected' : '' %>>Paid</option>
                      <option value="cancelled" <%= b.status==='cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Cập nhật">
                      <i class="bi bi-check2"></i>
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../../layouts/footer') %>
