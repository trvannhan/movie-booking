<%- include('layouts/header') %>

<!-- HERO CAROUSEL -->
<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
  <div class="carousel-inner">

    <% nowShowing.forEach((movie, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">

        <div class="hero-carousel-item">

          <!-- Background Image -->
          <img 
            src="<%= movie.posterUrl || '/images/movie-poster.svg' %>" 
            class="hero-carousel-img"
            onerror="this.onerror=null;this.src='/images/movie-poster.svg';"
          >

          <!-- Overlay -->
          <div class="hero-overlay-dark"></div>

          <!-- Content -->
          <div class="hero-content">
            <h1 class="hero-title"><%= movie.title %></h1>
            <p class="hero-genre"><%= movie.genre.join(', ') %></p>

            <a href="/movies/<%= movie._id %>" class="btn btn-danger btn-lg mt-3">
              <i class="bi bi-ticket-perforated"></i> Đặt vé ngay
            </a>
          </div>

        </div>

      </div>
    <% }) %>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<!-- PHIM ĐANG CHIẾU -->
<section class="container mt-5">
  <div class="d-flex justify-content-between align-items-center">
  <h2 class="section-title m-0">
    <i class="bi bi-fire text-danger"></i> Phim đang chiếu
  </h2>
  <a href="/movies" class="view-all-link">
    View all <i class="bi bi-arrow-right"></i>
  </a>
</div>
  <div class="row mt-3">
    <% if (nowShowing.length > 0) { %>
      <% nowShowing.forEach(movie => { %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
          <div class="card movie-card h-100 shadow-sm">
            <img src="<%= movie.posterUrl || '/images/movie-poster.svg' %>"
                 class="card-img-top movie-poster" alt="<%= movie.title %>" onerror="this.onerror=null;this.src='/images/movie-poster.svg';">
            <div class="card-body">
              <h6 class="card-title fw-bold"><%= movie.title %></h6>
             <div class="movie-meta">
              <span><i class="bi bi-clock"></i> <%= movie.duration %> phút</span>
              <span><i class="bi bi-tag"></i> <%= movie.genre.join(', ') %></span>
            </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
              <a href="/movies/<%= movie._id %>" class="btn btn-outline-danger btn-sm w-100">
                <i class="bi bi-ticket-perforated"></i> Đặt vé
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-camera-reels display-1 text-muted"></i>
        <p class="text-muted mt-3">Chưa có phim nào. Hãy thêm phim trong trang Admin!</p>
      </div>
    <% } %>
  </div>
</section>

<!-- PHIM SẮP CHIẾU -->
<section class="container mt-5">
  <h2 class="section-title">
    <i class="bi bi-calendar-event text-primary"></i> Phim sắp chiếu
  </h2>
  <div class="row mt-3">
    <% if (comingSoon.length > 0) { %>
      <% comingSoon.forEach(movie => { %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
          <div class="card movie-card upcoming-card h-100 shadow-sm">
            <img src="<%= movie.posterUrl || '/images/movie-poster.svg' %>"
                 class="card-img-top movie-poster" alt="<%= movie.title %>" onerror="this.onerror=null;this.src='/images/movie-poster.svg';">
            <div class="card-body">
              <h6 class="card-title fw-bold"><%= movie.title %></h6>
              <p class="small text-muted">
                <i class="bi bi-calendar"></i> Khởi chiếu: <%= new Date(movie.releaseDate).toLocaleDateString('vi-VN') %>
              </p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
              <a href="/movies/<%= movie._id %>" class="btn btn-outline-primary btn-sm w-100">
                <i class="bi bi-info-circle"></i> Xem chi tiết
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-4">
        <p class="text-muted">Chưa có phim sắp chiếu.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('layouts/footer') %>