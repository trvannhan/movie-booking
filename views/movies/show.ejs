<%- include('../layouts/header') %>
<div class="container mt-5">
  <div class="row g-4">
    <div class="col-lg-4">
      <img src="<%= movie.posterUrl || '/images/movie-poster.svg' %>" class="img-fluid rounded shadow-lg w-100" alt="<%= movie.title %>" onerror="this.onerror=null;this.src='/images/movie-poster.svg';">
    </div>
    <div class="col-lg-8">
      <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        <h2 class="mb-0"><%= movie.title %></h2>
        <% if (movie.status === 'now_showing') { %>
          <span class="badge bg-danger">Đang chiếu</span>
        <% } else if (movie.status === 'coming_soon') { %>
          <span class="badge bg-primary">Sắp chiếu</span>
        <% } else { %>
          <span class="badge bg-secondary">Ngừng chiếu</span>
        <% } %>
      </div>

      <div class="d-flex flex-wrap gap-3 text-secondary mb-3">
        <span><i class="bi bi-tags"></i> <%= movie.genre.join(', ') %></span>
        <span><i class="bi bi-clock"></i> <%= movie.duration %> phút</span>
        <% if (movie.releaseDate) { %>
          <span><i class="bi bi-calendar-event"></i> <%= new Date(movie.releaseDate).toLocaleDateString('vi-VN') %></span>
        <% } %>
      </div>

      <div class="card border-secondary mb-3">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <strong class="text-light">Đạo diễn</strong>
              <p class="text-secondary mb-0"><%= movie.director || 'Đang cập nhật' %></p>
            </div>
            <div class="col-md-6">
              <strong class="text-light">Diễn viên</strong>
              <p class="text-secondary mb-0"><%= movie.cast.length ? movie.cast.join(', ') : 'Đang cập nhật' %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-secondary mb-4">
        <div class="card-header bg-dark border-secondary">
          <strong>Nội dung phim</strong>
        </div>
        <div class="card-body">
          <p class="mb-0 text-secondary"><%= movie.description || 'Nội dung đang được cập nhật.' %></p>
        </div>
      </div>

      <% if (trailerEmbedUrl) { %>
        <div class="card border-secondary mb-4">
          <div class="card-header bg-dark border-secondary">
            <strong>Trailer</strong>
          </div>
          <div class="card-body">
            <div class="ratio ratio-16x9">
              <iframe src="<%= trailerEmbedUrl %>" title="Trailer <%= movie.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
          </div>
        </div>
      <% } %>

      <h4 class="mt-4"><i class="bi bi-calendar-event"></i> Lịch chiếu</h4>
      <% if (Object.keys(groupedShowtimes).length > 0) { %>
        <% Object.keys(groupedShowtimes).forEach(cinemaName => { %>
          <div class="card mb-3">
            <div class="card-header bg-dark text-white fw-bold">
              <%= cinemaName %>
            </div>
            <div class="card-body p-3">
              <div class="d-flex flex-wrap gap-2">
                <% groupedShowtimes[cinemaName].forEach(st => { %>
                  <% const timeStr = new Date(st.startTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}); %>
                  <% const dateStr = new Date(st.startTime).toLocaleDateString('vi-VN'); %>
                  <% const priceDisplay = (movie.basePrice * st.priceMultiplier).toLocaleString('vi-VN') + 'đ'; %>
                  <a href="/showtimes/<%= st._id %>/book" class="btn btn-outline-danger">
                    <div class="fw-bold fs-5"><%= timeStr %></div>
                    <div class="small"><%= dateStr %> | <%= st.roomId.name %></div>
                    <div class="small text-muted"><%= priceDisplay %></div>
                  </a>
                <% }) %>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="alert alert-warning">Hiện chưa có lịch chiếu cho phim này.</div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../layouts/footer') %>
