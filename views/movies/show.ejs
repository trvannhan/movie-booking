<%- include('../layouts/header') %>
<div class="container mt-5">
  <div class="row">
    <div class="col-md-4">
      <img src="<%= movie.posterUrl %>" class="img-fluid rounded shadow" alt="<%= movie.title %>">
    </div>
    <div class="col-md-8">
      <h2><%= movie.title %></h2>
      <p class="text-muted"><%= movie.genre.join(', ') %>  |  <i class="bi bi-clock"></i> <%= movie.duration %> phút</p>
      <p><strong>Đạo diễn:</strong> <%= movie.director %></p>
      <p><strong>Diễn viên:</strong> <%= movie.cast.join(', ') %></p>
      <p><%= movie.description %></p>

      <h4 class="mt-4"><i class="bi bi-calendar-event"></i> Lịch Chiếu</h4>
      <% if (Object.keys(groupedShowtimes).length > 0) { %>
         <% Object.keys(groupedShowtimes).forEach(cinemaName => { %>
            <div class="card mb-3">
               <div class="card-header bg-dark text-white fw-bold">
                 <%= cinemaName %>
               </div>
               <div class="card-body p-3">
                 <div class="d-flex flex-wrap gap-2">
                   <% groupedShowtimes[cinemaName].forEach(st => { %>
                      <% 
                         const timeStr = new Date(st.startTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                         const priceDisplay = (movie.basePrice * st.priceMultiplier).toLocaleString() + 'đ';
                      %>
                      <a href="/showtimes/<%= st._id %>/book" class="btn btn-outline-danger">
                        <div class="fw-bold fs-5"><%= timeStr %></div>
                        <div class="small"><%= st.roomId.name %></div>
                        <div class="small text-muted"><%= priceDisplay %></div>
                      </a>
                   <% }) %>
                 </div>
               </div>
            </div>
         <% }) %>
      <% } else { %>
         <div class="alert alert-warning">Hiện chưa có lịch chiếu cho phim này.</div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../layouts/footer') %>
