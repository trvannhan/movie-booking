<%- include('../layouts/header') %>
<div class="container mt-5">
   <div class="row justify-content-center">
      <div class="col-md-6 text-center">
         <h2 class="text-danger mb-4"><i class="bi bi-qr-code-scan"></i> Thanh Toán Vé</h2>
         
         <div class="card shadow-lg p-4 mb-4 border-0 rounded-4">
            <h5 class="fw-bold mb-3">Tổng Tiền: <%= booking.totalAmount.toLocaleString() %>đ</h5>
            
            <!-- QR CODE TỪ VIETQR -->
            <div class="mb-3">
               <img src="<%= qrUrl %>" alt="QR Code Payment" class="img-fluid border rounded" style="max-width: 300px;">
            </div>
            
            <p class="text-secondary small">Mở ứng dụng ngân hàng và quét mã để thanh toán tự động.</p>
            <p class="bg-dark p-2 rounded small text-start">
               <strong>Lý do: </strong>Thanh toan ve thu <%= booking._id.toString().substring(18) %>
            </p>
         </div>

         <form action="/bookings/<%= booking._id %>/confirm" method="POST">
            <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill shadow">Đã Thanh Toán Khẩu Hoàn Tất</button>
         </form>
         <div class="mt-3">
            <a href="/" class="text-muted">Hủy & Về Trang chủ</a>
         </div>
      </div>
   </div>
</div>
<%- include('../layouts/footer') %>
