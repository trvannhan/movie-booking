<%- include('../layouts/header') %>

<link rel="stylesheet" href="/css/book.css">

<div class="container mt-4">
  <div class="row">
    <div class="col-md-8">
       <h4 class="mb-3">1. Chon ghe</h4>

       <div class="card shadow-sm mb-4">
          <div class="card-body">

             <div class="screen-curve"><span class="text-muted pb-1">MAN HINH</span></div>

             <div class="seat-map mt-4">
                <% seatMap.forEach(row => { %>
                   <div class="seat-row">
                      <div class="row-number"><%= row.rowLetter %></div>
                      <% row.seats.forEach(seat => { %>
                         <div class="seat <%= seat.type %> <%= seat.isBooked ? 'booked' : '' %>"
                              data-code="<%= seat.code %>"
                              data-type="<%= seat.type %>"
                              data-price="<%= seat.price %>">
                            <%= seat.code %>
                         </div>
                      <% }) %>
                      <div class="row-number"><%= row.rowLetter %></div>
                   </div>
                <% }) %>
             </div>

             <div class="mt-4 seat-legend">
               <div class="legend-item"><span class="legend-seat"></span> Thuong</div>
               <div class="legend-item"><span class="legend-seat vip"></span> VIP</div>
               <div class="legend-item"><span class="legend-seat couple"></span> Couple</div>
               <div class="legend-item"><span class="legend-seat selected"></span> Dang chon</div>
               <div class="legend-item"><span class="legend-seat booked"></span> Da ban</div>
             </div>

          </div>
       </div>

       <h4 class="mb-3">2. Combo bap nuoc</h4>
       <div class="card shadow-sm mb-4 border-0">
          <ul class="list-group list-group-flush">
             <% services.forEach(svc => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                   <div>
                     <h6 class="mb-0"><%= svc.name %></h6>
                     <span class="text-danger fw-bold"><%= svc.price.toLocaleString('vi-VN') %>d</span>
                   </div>
                   <div class="d-flex align-items-center">
                     <button type="button" class="btn btn-sm btn-outline-secondary btn-minus"
                        data-service="<%= svc.name %>"
                        data-price="<%= svc.price %>"
                        data-service-id="<%= svc.id %>">-</button>

                     <span class="mx-3 qty-label" id="qty-<%= svc.id %>">0</span>

                     <button type="button" class="btn btn-sm btn-outline-secondary btn-plus"
                        data-service="<%= svc.name %>"
                        data-price="<%= svc.price %>"
                        data-service-id="<%= svc.id %>">+</button>
                   </div>
                </li>
             <% }) %>
          </ul>
       </div>

       <h4 class="mb-3">3. Ma giam gia</h4>
       <div class="card shadow-sm mb-4 border-0">
          <div class="card-body">
            <div class="row g-3 align-items-center">
              <div class="col-md-8">
                <input type="text" id="discountCodeInput" class="form-control bg-dark text-light border-secondary">
              </div>
              <div class="col-md-4 d-grid">
                <button type="button" id="btn-apply-promo" class="btn btn-outline-warning">Ap dung ma</button>
              </div>
            </div>

            <div class="mt-3 d-flex flex-wrap gap-2">
              <% promotions.forEach(promo => { %>
                <button type="button"
                        class="btn btn-sm btn-outline-light promo-chip"
                        data-code="<%= promo.code %>">
                  <%= promo.code %>
                </button>
              <% }) %>
            </div>

            <small class="text-secondary d-block mt-2" id="promo-message"></small>
          </div>
       </div>
    </div>

    <div class="col-md-4">
       <div class="card shadow-sm sticky-top" style="top: 20px;">
          <img src="<%= showtime.movieId.posterUrl || '/images/movie-poster.svg' %>" class="card-img-top">

          <div class="card-body">
             <h5><%= showtime.movieId.title %></h5>

             <p class="text-muted small">
               <%= showtime.cinemaId.name %> | <%= showtime.roomId.name %>
             </p>

             <hr>

             <p><strong>Ghe: </strong><span id="selected-seats-display"></span></p>
             <p><strong>Tien ghe: </strong><span id="seats-total-display">0d</span></p>
             <p><strong>Dich vu: </strong><span id="services-total-display">0d</span></p>
             <p><strong>Tam tinh: </strong><span id="subtotal-display">0d</span></p>
             <p><strong>Giam gia: </strong><span id="discount-display">0d</span></p>

             <hr>

             <h4 class="text-danger">
               Tong: <span id="grand-total-display">0d</span>
             </h4>

             <form action="/bookings/checkout" method="POST" id="checkout-form">
                <input type="hidden" name="showtimeId" value="<%= showtime._id %>">
                <input type="hidden" id="ticketsData" name="ticketsData">
                <input type="hidden" id="servicesData" name="servicesData">
                <input type="hidden" id="discountCode" name="discountCode">
                <input type="hidden" id="totalAmount" name="totalAmount">

                <button type="submit" id="btn-checkout" class="btn btn-danger w-100" disabled>
                  Thanh toan
                </button>
             </form>

          </div>
       </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>

<script src="/js/book.js"></script>